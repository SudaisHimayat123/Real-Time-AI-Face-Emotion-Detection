# ============================================================
# AI Face Emotion Overlay - Environment Variables
# Copy this file to .env and fill in values
# ============================================================

# App Settings
APP_ENV=development
DEBUG=false

# Camera Settings
CAMERA_DEVICE_ID=0
CAMERA_WIDTH=1280
CAMERA_HEIGHT=720

# Model Settings
EMOTION_MODEL=fer
FACE_DETECTION_CONFIDENCE=0.6

# Recording
AUTO_SAVE_RECORDINGS=false
OUTPUT_DIR=outputs/videos

# Web API (if using web version)
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Database
DB_PATH=outputs/sessions.db
